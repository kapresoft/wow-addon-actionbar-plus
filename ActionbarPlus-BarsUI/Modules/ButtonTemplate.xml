<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">

	<CheckButton name="ABP_ButtonTemplate_2_0" virtual="true">
        <Size>
            <AbsDimension x="36" y="36"/>
        </Size>
        <Layers>
            <Layer level="ARTWORK" textureSubLevel="-2">
                <Texture parentKey="icon" name="$parentIcon" alpha="0.8">
                    <Anchors>
                        <!--<Anchor point="TOPLEFT" relativePoint="TOPLEFT" x="1" y="-1"/>
                        <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" x="-1" y="1"/>-->
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="ARTWORK" textureSubLevel="-1">
                <MaskTexture parentKey="IconMask" file="interface\addons\actionbarplus\core\assets\textures\ui-button-mask">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parentIcon"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parentIcon"/>
                   </Anchors>
                </MaskTexture>
            </Layer>
            <Layer level="ARTWORK" textureSubLevel="2">
                <FontString name="$parentHotKey" inherits="NumberFontNormalSmallGray" parentKey="HotKey" justifyH="RIGHT">
                    <Size x="32" y="10"/>
                    <Anchors>
                        <Anchor point="TOPRIGHT" x="-5" y="-5"/>
                    </Anchors>
                </FontString>
                <FontString name="$parentCount" inherits="NumberFontNormal" parentKey="Count" justifyH="RIGHT">
                    <Anchors>
                        <Anchor point="BOTTOMRIGHT" x="-2" y="2"/>
                    </Anchors>
                </FontString>
            </Layer>
            <Layer level="OVERLAY">
                <FontString name="$parentName" parentKey="Name" inherits="GameFontHighlightSmallOutline"
                            maxLines="1">
                    <Anchors>
                        <Anchor point="BOTTOM" x="0" y="2"/>
                    </Anchors>
                </FontString>
                <Texture name="$parentBorder" file="Interface\Buttons\UI-ActionButton-Border" parentKey="Border" hidden="true" alphaMode="ADD">
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
            <Layer level="OVERLAY" textureSubLevel="1">
                <Texture name="$parentNewActionTexture" parentKey="NewActionTexture" atlas="bags-newitem" useAtlasSize="false" alphaMode="ADD" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
                <Texture name="$parentSpellHighlightTexture" parentKey="SpellHighlightTexture"
                         atlas="bags-newitem" useAtlasSize="false" alphaMode="ADD" setAllPoints="true" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
                <Texture name="$parentAutoCastable" parentKey="AutoCastable" file="Interface\Buttons\UI-AutoCastableOverlay"
                         setAllPoints="true" hidden="true">
                    <Anchors>
                        <Anchor point="TOPLEFT"/>
                        <Anchor point="BOTTOMRIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>
        <Animations>
            <AnimationGroup parentKey="SpellHighlightAnim" looping="REPEAT">
                <Alpha childKey="SpellHighlightTexture" smoothing="OUT" duration=".35" order="1" fromAlpha="0" toAlpha="1"/>
                <Alpha childKey="SpellHighlightTexture" smoothing="IN" duration=".35" order="2" fromAlpha="1" toAlpha="0"/>
                <Scripts>
                    <OnPlay>
                        local btn = self:GetParent()
                        local tex = btn and btn.SpellHighlightTexture; if not tex then return end
                        -- others: FACTION_GREEN_COLOR, RED_THREAT_COLOR
                        local c = YELLOW_THREAT_COLOR
                        tex:SetVertexColor(c.r, c.g, c.b, c.a)
                        tex:Show();
                    </OnPlay>
                </Scripts>
            </AnimationGroup>
        </Animations>
        <Frames>
            <Cooldown parentKey="cooldown" inherits="CooldownFrameTemplate" setAllPoints="true" drawEdge="false">
                <KeyValues>
                    <KeyValue key="edgeTextureNormal" value="Interface\Cooldown\edge-LoC" type="string"/>
                    <KeyValue key="edgeTextureLOC" value="Interface\Cooldown\edge" type="string"/>
                </KeyValues>
                <Anchors>
                    <Anchor point="TOPLEFT" relativePoint="TOPLEFT" x="1" y="-1"/>
                    <Anchor point="BOTTOMRIGHT" relativePoint="BOTTOMRIGHT" x="-1" y="1"/>
                </Anchors>
                <SwipeTexture>
                    <Color r="0" g="0" b="0" a="0.6"/>
                </SwipeTexture>
            </Cooldown>
        </Frames>
        <NormalTexture parentKey="NormalTexture" file="interface\addons\actionbarplus\Core\Assets\Textures\ui-button-empty"/>
        <PushedTexture parentKey="PushedTexture" file="Interface\Buttons\UI-Quickslot-Depress" alpha="0.6" alphaMode="ADD"/>
        <HighlightTexture parentKey="HighlightTexture" alphaMode="ADD" file="Interface\Buttons\ButtonHilight-Square"/>
        <CheckedTexture parentKey="CheckedTexture" alphaMode="ADD" file="Interface\Buttons\CheckButtonHilight"/>
	</CheckButton>

</Ui>
