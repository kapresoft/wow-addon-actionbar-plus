<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">

    <Button name="ABP_OptionsUI_ResetButtonTemplate_2_0" inherits="IconButtonTemplate"
            parentKey="ResetButton" registerForClicks="LeftButtonUp" virtual="true">
