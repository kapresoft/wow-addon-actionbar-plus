            <KeyValue key="tooltipText" value="RESET_THEME_TOOLTIP" type="global"/>
        </KeyValues>
    </Button>
    <Button name="ABP_OptionsUI_SettingsIconButtonTemplate_2_0" inherits="IconButtonTemplate"
